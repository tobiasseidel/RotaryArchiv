# Database
POSTGRES_HOST=sqlite
SQLITE_PATH=/app/data/rotary_archiv.db

# File Storage
DOCUMENTS_PATH=/app/data/documents
TRIPLESTORE_PATH=/app/data/triplestore.ttl

# OCR - Ollama (auf NAS-Host)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_VISION_MODEL=deepseek-ocr:latest
OLLAMA_GPT_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT_SECONDS=7200

# Wikidata
WIKIDATA_API_URL=https://www.wikidata.org/w/api.php
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Poppler (leer = verwendet System-Poppler aus PATH)
POPPLER_PATH=