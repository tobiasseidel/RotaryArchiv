# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rotary_archiv
POSTGRES_USER=rotary_user
POSTGRES_PASSWORD=change_me

# Triple Store (Fuseki)
FUSEKI_HOST=localhost
FUSEKI_PORT=3030
FUSEKI_DATASET=rotary_archiv

# File Storage
DOCUMENTS_PATH=./data/documents

# OCR
TESSERACT_CMD=tesseract
# Tesseract einbeziehen (Standard: aus). Bei true wird Tesseract zusätzlich zu Ollama Vision genutzt.
TESSERACT_ENABLED=false
# Debug: ausgeschnittene BBox-Bilder speichern (Standard: aus). Für Entwicklung/Debug: true
DEBUG_SAVE_BBOX_CROPS=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava
OLLAMA_GPT_MODEL=llama3

# Wikidata
WIKIDATA_API_URL=https://www.wikidata.org/w/api.php
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
