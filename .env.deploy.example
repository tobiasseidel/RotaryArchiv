# RotaryArchiv Deploy-Konfiguration
# Kopiere diese Datei nach .env.deploy und passe die Werte an.
# .env.deploy ist in .gitignore, nie einchecken!

# NAS-SSH-Benutzer
DEPLOY_USER=rotary

# NAS-Hostname oder IP
DEPLOY_HOST=nas

# Zielverzeichnis auf der NAS
DEPLOY_PATH=/volume1/docker/rotary-archive/frontend-b/dist
